# LADDER proxy configuration. Copy to `.env` and fill in for the target network.
# Load it however your process manager does (systemd EnvironmentFile=, an
# `env $(cat .env)` wrapper, docker --env-file, etc.).

# --- Model endpoint (OpenAI-compatible chat-completions, full path) ---
LADDER_ENDPOINT_URL=https://mistral.internal.example/v1/chat/completions
LADDER_MODEL=mistral-medium-2508
LADDER_MAX_TOKENS=1000
LADDER_TIMEOUT_S=120

# --- Kerberos (target service) ---
# Usually leave LADDER_SPN unset: httpx-gssapi derives HTTP@<host> from the URL.
# LADDER_SPN=HTTP@mistral.internal.example
LADDER_MUTUAL_AUTH=optional        # required | optional | disabled

# --- TLS ---
# Path to your internal CA bundle, or "false" to skip verification (trusted net).
LADDER_TLS_VERIFY=/etc/ladder/internal-ca.pem

# --- Static SPA ---
# Absolute path to the built Vite `dist/`. Leave empty to run API-only.
LADDER_STATIC_DIR=/opt/ladder/dist

# --- Kerberos client identity (how THIS service proves who it is) ---
# Keytab-based is best for a long-running service: GSSAPI re-acquires tickets
# automatically, so nothing expires. Point at the service's client keytab:
KRB5_CLIENT_KTNAME=/etc/ladder/ladder.keytab
# ...or drive a credential cache yourself (e.g. a kinit -k sidecar/cron):
# KRB5CCNAME=FILE:/run/ladder/krb5cc
